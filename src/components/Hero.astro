---
import { ChevronRight, Download } from '@lucide/astro';
---

<section id="hero" class="min-h-screen flex flex-col justify-center section-padding pt-32">
  <div class="max-w-4xl">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 text-xs font-semibold mb-6 animate-fade-in">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
      </span>
      Disponible para nuevos proyectos
    </div>
    
    <h1 class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight">
      Edinson Medina Chinga
    </h1>
    <h2 class="text-3xl md:text-4xl text-slate-500 dark:text-slate-400 font-medium mb-8">
      Full Stack Developer
    </h2>
    
    <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 mb-10 max-w-2xl leading-relaxed">
      +4 años creando soluciones escalables en los sectores financiero, logístico y cobranzas. 
      Especializado en arquitecturas modernas con <span class="text-slate-900 dark:text-white font-medium underline decoration-accent">Angular, NestJS, Spring Boot y GCP</span>, optimizando flujos operativos y rendimiento web.
    </p>
    
    <div class="flex flex-wrap gap-4">
      <a 
        href="#experiencia" 
        class="px-8 py-4 bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-xl font-bold flex items-center gap-2 hover:translate-y-[-2px] transition-all shadow-lg hover:shadow-xl"
      >
        Ver Experiencia <ChevronRight size={18} />
      </a>
      <a 
        href="#proyectos" 
        class="px-8 py-4 bg-white dark:bg-slate-900 text-slate-900 dark:text-white border border-slate-200 dark:border-slate-800 rounded-xl font-bold flex items-center gap-2 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all"
      >
        Proyectos Clave
      </a>
      <a 
        href="/CV_EdinsonMedinaChinga_2026.pdf" 
        download="CV_EdinsonMedinaChinga_2026.pdf"
        class="px-8 py-4 text-slate-600 dark:text-slate-400 font-semibold flex items-center gap-2 hover:text-slate-900 dark:hover:text-white transition-colors"
      >
        <Download size={18} /> Descargar CV
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }
</style>
