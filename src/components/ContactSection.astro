---
import { Mail, Linkedin, Github, Phone } from '@lucide/astro';
---

<section id="contacto" class="section-padding">
  <div class="glass-card rounded-[32px] p-8 md:p-16 text-center max-w-5xl mx-auto border-accent/20">
    <h2 class="text-sm font-bold text-accent uppercase tracking-widest mb-4">¿Hablamos?</h2>
    <p class="text-4xl md:text-5xl font-bold dark:text-white mb-8">Impulsemos tu próximo <br class="hidden sm:block" /> producto juntos.</p>
    
    <p class="text-slate-600 dark:text-slate-400 text-lg mb-12 max-w-2xl mx-auto">
      Abierto a oportunidades como Desarrollador Full Stack para proyectos de alto impacto financiero y logístico.
    </p>

    <div class="flex flex-wrap justify-center gap-6">
      <a 
        href="mailto:edmech25@gmail.com" 
        class="px-8 py-4 bg-accent text-white rounded-xl font-bold flex items-center gap-3 hover:scale-105 transition-transform"
      >
        <Mail size={20} /> edmech25@gmail.com
      </a>
      
      <div class="flex items-center gap-4">
        <a 
          href="https://linkedin.com/in/edinson-medina-chinga" 
          target="_blank" 
          class="p-4 rounded-xl border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 hover:text-accent hover:border-accent transition-all"
          aria-label="LinkedIn"
        >
          <Linkedin size={24} />
        </a>
        <a 
          href="https://github.com/28Emc" 
          target="_blank" 
          class="p-4 rounded-xl border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 hover:text-accent hover:border-accent transition-all"
          aria-label="GitHub"
        >
          <Github size={24} />
        </a>
        <a 
          href="tel:+51902564211" 
          class="p-4 rounded-xl border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 hover:text-accent hover:border-accent transition-all"
          aria-label="Teléfono"
        >
          <Phone size={24} />
        </a>
      </div>
    </div>
  </div>
</section>
